@model IEnumerable<NorthwindApp.Models.Orders>

@{
    ViewBag.Title = "Lista de Pedidos";
    Layout = "~/Views/Shared/_Main.cshtml";
}

<h2>Lista de Pedidos</h2>
<hr />

<form action="~/Orders/ListaOrders" method="post" class="align-items">
    <div class="row g-2 justify-content-center">
        <div class="col-md-6">
            <input required type="number" min="0" name="orderid" class="form-control" placeholder="Buscar por ID..." />
        </div>
        <div class="col-auto">
            <button class="btn btn-secondary" type="submit">Buscar</button>
        </div>
    </div>
</form>

<p>
    @Html.ActionLink("Registrar Nuevo", "Create",null,new {@class="btn btn-primary"})
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.OrderID)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.OrderDate)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ShipName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ShipAddress)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ShipCity)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ShipPostalCode)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ShipCountry)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.OrderID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OrderDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShipName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShipAddress)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShipCity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShipPostalCode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShipCountry)
            </td>
            <td>
                <a href="@Url.Action("DetallesOrders","Orders",new {orderId = item.OrderID})" class="btn btn-sm btn-outline-info" title="Ver">
                    <i class="bi bi-eye"></i>
                </a>
                <a href="#" class="btn btn-sm btn-outline-warning" title="Editar">
                    <i class="bi bi-pencil"></i>
                </a>
                <a href="#" class="btn btn-sm btn-outline-danger" title="Ver">
                    <i class="bi bi-trash"></i>
                </a>
            </td>
        </tr>
    }

</table>

@{
    int totalPaginas = ViewBag.TotalPaginas;
    int paginaActual = ViewBag.PaginaActual;
    int rango = 2; // cantidad de páginas visibles a cada lado
}

<nav>
    <ul class="pagination justify-content-center">
        <!-- Botón "Anterior" -->
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            @Html.ActionLink("«", "ListaOrders", new { pagina = paginaActual - 1 }, new { @class = "page-link" })
        </li>

        <!-- Primera página -->
        @if (paginaActual > rango + 2)
        {
            <li class="page-item">
                @Html.ActionLink("1", "ListaOrders", new { pagina = 1 }, new { @class = "page-link" })
            </li>
            <li class="page-item disabled"><span class="page-link">...</span></li>
        }

        <!-- Páginas alrededor de la actual -->
        @for (int i = Math.Max(1, paginaActual - rango); i <= Math.Min(totalPaginas, paginaActual + rango); i++)
        {
            <li class="page-item @(i == paginaActual ? "active" : "")">
                @Html.ActionLink(i.ToString(), "ListaOrders", new { pagina = i }, new { @class = "page-link" })
            </li>
        }

        <!-- Última página -->
        @if (paginaActual < totalPaginas - rango - 1)
        {
            <li class="page-item disabled"><span class="page-link">...</span></li>
            <li class="page-item">
                @Html.ActionLink(totalPaginas.ToString(), "ListaOrders", new { pagina = totalPaginas }, new { @class = "page-link" })
            </li>
        }

        <!-- Botón "Siguiente" -->
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            @Html.ActionLink("»", "Lista", new { pagina = paginaActual + 1 }, new { @class = "page-link" })
        </li>
    </ul>
</nav>

<p class="text-center text-muted">Total: @ViewBag.TotalRegistros registros</p>
