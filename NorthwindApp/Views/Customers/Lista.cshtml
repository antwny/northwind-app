@model IEnumerable<NorthwindApp.Models.Customers>

@{
    ViewBag.Title = "Lista de Clientes";
    Layout = "~/Views/Shared/_Main.cshtml";
}

<h2>Lista de Clientes</h2>
<hr />

<form action="~/Customers/Lista" method="post" class="align-items">
    <div class="row g-2 justify-content-center">
        <div class="col-md-6">
            <input required type="text" name="nombre" class="form-control" placeholder="Buscar por nombre de empresa..." />
        </div>
        <div class="col-auto">
            <button class="btn btn-secondary" type="submit">Buscar</button>
        </div>
    </div>
</form>
<p>
    @Html.ActionLink("Registrar Nuevo", "Registrar", null, new { @class = "btn btn-primary" })
</p>
<table class="table">
    <tr>

        <th>
            @Html.DisplayNameFor(model => model.CompanyName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ContactName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ContactTitle)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Address)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.City)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Region)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.PostalCode)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Country)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Phone)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Fax)
        </th>
        <th>Acciones</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>

            <td>
                @Html.DisplayFor(modelItem => item.CompanyName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ContactName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ContactTitle)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.City)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Region)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PostalCode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Country)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Fax)
            </td>
            <td>
                <a href="@Url.Action("Detalles","",new {customerId = item.CustomerID})" class="btn btn-sm btn-outline-info" title="Ver Detalles">
                    <i class="bi bi-eye"></i>
                </a>
                <a href="@Url.Action("Editar","Customers",new {customerId = item.CustomerID})" class="btn btn-sm btn-outline-warning" title="Editar">
                    <i class="bi bi-pencil"></i>
                </a>
                <a href="@Url.Action("Eliminar","Customers",new {customerId = item.CustomerID})" class="btn btn-sm btn-outline-danger" onclick="confirmarEliminar(event, this.href)" title="Eliminar">
                    <i class="bi bi-trash"></i>
                </a>
            </td>
        </tr>
    }

</table>

@{
    int totalPaginas = ViewBag.TotalPaginas;
    int paginaActual = ViewBag.PaginaActual;
    int rango = 2; // cantidad de páginas visibles a cada lado
}

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">

        <!-- Botón "Anterior" -->
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            @Html.ActionLink("«", "Lista", new { pagina = paginaActual - 1 }, new { @class = "page-link", aria_label = "Anterior" })
        </li>

        <!-- Primera página -->
        @if (paginaActual > rango + 2)
        {
            <li class="page-item">
                @Html.ActionLink("1", "Lista", new { pagina = 1 }, new { @class = "page-link" })
            </li>
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        <!-- Páginas alrededor de la actual -->
        @for (int i = Math.Max(1, paginaActual - rango); i <= Math.Min(totalPaginas, paginaActual + rango); i++)
        {
            <li class="page-item @(i == paginaActual ? "active" : "")">
                @Html.ActionLink(i.ToString(), "Lista", new { pagina = i }, new { @class = "page-link" })
            </li>
        }

        <!-- Última página -->
        @if (paginaActual < totalPaginas - rango - 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
            <li class="page-item">
                @Html.ActionLink(totalPaginas.ToString(), "Lista", new { pagina = totalPaginas }, new { @class = "page-link" })
            </li>
        }

        <!-- Botón "Siguiente" -->
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            @Html.ActionLink("»", "Lista", new { pagina = paginaActual + 1 }, new { @class = "page-link", aria_label = "Siguiente" })
        </li>
    </ul>
</nav>

<p class="text-center text-muted">Total: @ViewBag.TotalRegistros registros</p>

<script>

    function confirmarEliminar(evento, url) {
        evento.preventDefault(); // evitar navegar al enlace directamente

        Swal.fire({
            title: "¿Estas seguro de eliminar?",
            showConfirmButton: false,
            showDenyButton: true,
            showCancelButton: true,
            denyButtonText: "Sí, eliminar.",
            cancelButtonText: "Cancelar"
        }).then((result) => {
            if (result.isDenied) {
                window.location.href = url;
            }
        });
    }
</script>

